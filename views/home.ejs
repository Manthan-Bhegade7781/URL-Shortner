<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>URL Shortener</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family:'Poppins', sans-serif;
        }

        body{
            min-height:100vh;
            background:linear-gradient(135deg,#0f172a,#1e293b);
            color:white;
        }

        /* NAVBAR */

        .navbar{
            position:sticky;
            top:0;
            z-index:1000;

            width:100%;

            display:flex;
            justify-content:space-between;
            align-items:center;

            padding:18px 40px;

            background:rgba(15,23,42,0.9);
            backdrop-filter:blur(15px);

            border-bottom:1px solid rgba(255,255,255,0.08);
        }

        .nav-logo{
            font-size:28px;
            font-weight:700;
            color:white;
        }

        .logout-btn{
            text-decoration:none;
            color:white;

            padding:12px 24px;

            border-radius:12px;

            background:linear-gradient(
                135deg,
                #ef4444,
                #dc2626
            );

            transition:0.3s;
        }

        .logout-btn:hover{
            transform:translateY(-2px);
            box-shadow:0 8px 20px rgba(239,68,68,0.4);
        }

        /* MAIN CONTENT */

        .main-content{
            width:100%;
            display:flex;
            justify-content:center;
            padding:40px 20px;
        }

        .dashboard{
            width: 100%;
            max-width: 1200px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.1);
            backdrop-filter: blur(14px);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
            margin-top: 10px;
        }

        h1{
            font-size: 36px;
            margin-bottom: 10px;
        }

        .subtitle{
            color: #cbd5e1;
            margin-bottom: 35px;
            line-height: 1.6;
        }

        form{
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        input{
            flex: 1;
            min-width: 250px;
            padding: 16px;
            border: none;
            outline: none;
            border-radius: 14px;
            background: rgb(17, 16, 16);
            color: white;
            font-size: 15px;
        }

        input::placeholder{
            color: #cbd5e1;
        }

        button{
            padding: 16px 30px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, #2563eb, #06b6d4);
            color: white;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s ease;
        }

        button:hover{
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(37,99,235,0.4);
        }

        .result-box{
            margin-top: 30px;
            padding: 20px;
            border-radius: 16px;
            background: rgba(15,23,42,0.7);
            border: 1px solid rgba(255,255,255,0.08);
        }

        .result-box h3{
            margin-bottom: 12px;
            color: #38bdf8;
        }

        .short-url{
            color: white;
            text-decoration: none;
            word-break: break-all;
            font-weight: 500;
        }

        .short-url:hover{
            color: #38bdf8;
        }

        /* TABLE SECTION */

        .table-container{
            margin-top: 35px;
            overflow-x: auto;
            border-radius: 18px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
        }

        table{
            width: 100%;
            border-collapse: collapse;
            min-width: 800px;
        }

        thead{
            background: linear-gradient(135deg, #2563eb, #06b6d4);
        }

        thead th{
            padding: 18px;
            text-align: left;
            font-size: 15px;
            font-weight: 600;
            color: white;
            letter-spacing: 0.5px;
        }

        tbody tr{
            transition: 0.3s ease;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        tbody tr:hover{
            background: rgba(255,255,255,0.06);
        }

        tbody td{
            padding: 18px;
            color: #e2e8f0;
            font-size: 14px;
            vertical-align: middle;
        }

        tbody td:first-child{
            font-weight: 600;
            color: #38bdf8;
        }

        tbody td a{
            color: #38bdf8;
            text-decoration: none;
            transition: 0.3s;
        }

        tbody td a:hover{
            text-decoration: underline;
            color: #67e8f9;
        }

        .visit-badge{
            display: inline-block;
            padding: 6px 12px;
            border-radius: 30px;
            background: rgba(56,189,248,0.15);
            color: #38bdf8;
            font-size: 13px;
            font-weight: 600;
        }

        .copy-btn{
            padding: 8px 14px;
            margin-left: 10px;

            border: none;
            border-radius: 8px;

            background: linear-gradient(
                135deg,
                #2563eb,
                #06b6d4
            );

            color: white;
            font-size: 13px;
            font-weight: 600;

            cursor: pointer;

            transition: all 0.3s ease;
        }

        .copy-btn:hover{
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(37,99,235,0.4);
        }

        .copy-btn:active{
            transform: scale(0.95);
        }

        .delete-btn{
            border:none;

            padding:8px 14px;

            border-radius:8px;

            background:linear-gradient(
                135deg,
                #ef4444,
                #dc2626
            );

            color:white;

            font-size:13px;
            font-weight:600;

            cursor:pointer;

            transition:0.3s;
        }

        .delete-btn:hover{
            transform:translateY(-2px);

            box-shadow:0 6px 15px rgba(239,68,68,0.4);
        }

        .delete-btn:active{
            transform:scale(0.95);
        }

        /* SCROLLBAR */

        .table-container::-webkit-scrollbar{
            height: 8px;
        }

        .table-container::-webkit-scrollbar-thumb{
            background: #2563eb;
            border-radius: 20px;
        }

        /* MOBILE */

       @media(max-width:768px){

            .navbar{
                padding:15px 20px;
            }

            .nav-logo{
                font-size:20px;
            }

            .logout-btn{
                padding:10px 16px;
                font-size:14px;
            }

            .main-content{
                padding:20px 10px;
            }

            .dashboard{
                padding:25px;
            }

            h1{
                font-size:28px;
            }

            form{
                flex-direction:column;
            }

            input{
                width:100%;
            }

            button{
                width:100%;
            }

            table{
                min-width:650px;
            }
        }

    </style>
</head>

<script>
function copyURL(url){
    navigator.clipboard.writeText(url);

    alert("URL copied successfully!");
}
</script>

<body>

    <!-- Navbar -->

    <nav class="navbar">

        <div class="nav-logo">
            🔗 URLShortener
        </div>

        <a href="/user/logout" class="logout-btn">
            Logout
        </a>

    </nav>

    <!-- Main Content -->

    <div class="main-content">

        <div class="dashboard">

            <p class="subtitle">
                Convert long URLs into short, clean, and shareable links instantly.
            </p>

            <form action="/url" method="POST">

                <input
                    type="text"
                    name="url"
                    placeholder="Enter your long URL here..."
                    required
                >

                <button type="submit">
                    Shorten URL
                </button>

            </form>

            <div class="result-box">

                <h3>Your Short URL</h3>

                <% if (locals.shortID) { %>

                    <a
                        class="short-url"
                        href="http://localhost:3000/url/<%= shortID %>"
                        target="_blank"
                    >
                        http://localhost:3000/url/<%= shortID %>
                    </a>

                <% } %>

            </div>

            <% if (locals.urls && urls.length > 0) { %>

                <div class="table-container">

                    <table>

                        <thead>
                            <tr>
                                <th>Sr.No.</th>
                                <th>Original URL</th>
                                <th>Short URL</th>
                                <th>Action</th>
                                <th>Action</th>
                                <th>Visit Count</th>
                            </tr>
                        </thead>

                        <tbody>

                            <% urls.forEach((url, index) => { %>

                                <tr>

                                    <td>
                                        <%= index + 1 %>
                                    </td>

                                    <td>
                                        <%= url.originalURL %>
                                    </td>

                                    <td>
                                        <a
                                            href="http://localhost:3000/url/<%= url.shortID %>"
                                            target="_blank"
                                        >
                                            http://localhost:3000/url/<%= url.shortID %>
                                        </a>

                                    </td>

                                    <td>
                                        <button
                                            class="copy-btn"
                                            onclick="copyURL('http://localhost:3000/url/<%= url.shortID %>')"
                                        >
                                            Copy
                                        </button>
                                    </td>

                                    <td>
                                                                

                                        <form
                                            action="/url/delete/<%= url._id %>"
                                            method="POST"
                                            onsubmit="return confirm('Are you sure you want to delete this URL?')"
                                        >

                                            <button type="submit" class="delete-btn">
                                                Delete
                                            </button>

                                        </form>

                                    </td>
                                    

                                    <td>
                                        <span class="visit-badge">
                                            <%= url.visitHistory.length %> Visits
                                        </span>
                                    </td>

                                </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>

            <% } %>

        </div>

    </div>

</body>

</html>